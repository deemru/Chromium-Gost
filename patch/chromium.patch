+int SSLClientSocketImpl::VerifyGOSTResult(uint32_t verify_result)
+{
+#ifndef TRUST_E_CERT_SIGNATURE
+#define TRUST_E_CERT_SIGNATURE          (uint32_t)0x80096004L
+#define CRYPT_E_REVOKED                 (uint32_t)0x80092010L
+#define CERT_E_UNTRUSTEDROOT            (uint32_t)0x800B0109L
+#define CERT_E_UNTRUSTEDTESTROOT        (uint32_t)0x800B010DL
+#define CERT_E_REVOCATION_FAILURE       (uint32_t)0x800B010EL
+#define CERT_E_EXPIRED                  (uint32_t)0x800B0101L
+#define CERT_E_INVALID_NAME             (uint32_t)0x800B0114L
+#define CERT_E_CN_NO_MATCH              (uint32_t)0x800B010FL
+#define CERT_E_VALIDITYPERIODNESTING    (uint32_t)0x800B0102L
+#define CRYPT_E_NO_REVOCATION_CHECK     (uint32_t)0x80092012L
+#define CRYPT_E_REVOCATION_OFFLINE      (uint32_t)0x80092013L
+#define CERT_E_CHAINING                 (uint32_t)0x800B010AL
+#endif
+
+  int gost_rv;
+  CertStatus cert_status = 0;
+  switch (verify_result) {
+  case 0:
+    gost_rv = OK;
+    break;
+  case (uint32_t)CERT_E_CN_NO_MATCH:
+  case (uint32_t)CERT_E_INVALID_NAME:
+    gost_rv = ERR_CERT_COMMON_NAME_INVALID;
+    cert_status |= CERT_STATUS_COMMON_NAME_INVALID;
+    break;
+  case (uint32_t)CERT_E_UNTRUSTEDROOT:
+  case (uint32_t)TRUST_E_CERT_SIGNATURE:
+  case (uint32_t)CERT_E_UNTRUSTEDTESTROOT:
+  case (uint32_t)CERT_E_CHAINING:
+    gost_rv = ERR_CERT_AUTHORITY_INVALID;
+    cert_status |= CERT_STATUS_AUTHORITY_INVALID;
+    break;
+  case (uint32_t)CERT_E_EXPIRED:
+  case (uint32_t)CERT_E_VALIDITYPERIODNESTING:
+    gost_rv = ERR_CERT_DATE_INVALID;
+    cert_status |= CERT_STATUS_DATE_INVALID;
+    break;
+  case (uint32_t)CRYPT_E_NO_REVOCATION_CHECK:
+  case (uint32_t)CERT_E_REVOCATION_FAILURE:
+    gost_rv = ERR_CERT_NO_REVOCATION_MECHANISM;
+    cert_status |= CERT_STATUS_NO_REVOCATION_MECHANISM;
+    break;
+  case (uint32_t)CRYPT_E_REVOCATION_OFFLINE:
+    gost_rv = ERR_CERT_UNABLE_TO_CHECK_REVOCATION;
+    cert_status |= CERT_STATUS_UNABLE_TO_CHECK_REVOCATION;
+    break;
+  case (uint32_t)CRYPT_E_REVOKED:
+    gost_rv = ERR_CERT_REVOKED;
+    cert_status |= CERT_STATUS_REVOKED;
+    break;
+  default:
+    gost_rv = ERR_CERT_INVALID;
+    cert_status |= CERT_STATUS_INVALID;
+    break;
+  }
+
+  server_cert_verify_result_.Reset();
+  server_cert_verify_result_.verified_cert = server_cert_;
+
+  cert_verification_result_ = gost_rv;
+  if (gost_rv != OK)
+  {
+    server_cert_verify_result_.cert_status = cert_status;
+    OpenSSLPutNetError(FROM_HERE, gost_rv);
+  }
+
+  return gost_rv;
+}
+void SSLClientSocketImpl::VerifyGOSTTaskComplete(uint32_t verify_result)
+{
+  OnVerifyComplete(VerifyGOSTResult(verify_result));
+}
